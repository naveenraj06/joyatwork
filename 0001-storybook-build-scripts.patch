From c638cf1cc43a44aef5aa49ca26ea91c00bc94a5f Mon Sep 17 00:00:00 2001
From: Naveen Rajiv <naveenrajiv.06@gmail.com>
Date: Wed, 1 Jul 2026 07:17:43 +0000
Subject: [PATCH] chore: separate storybook build from package build

- npm run build now builds Storybook (storybook-static/), matching
  the fact that Storybook is the project's dev/demo surface now that
  the preview app is gone
- npm run build:package builds the actual publishable npm package
  (react bundle + web-component bundle + type declarations into dist/)
- npm run build:all / prepublishOnly unchanged in effect: still
  clean + build:package, so npm publish never ships Storybook output
- npm run preview now serves the built storybook-static/ output
- kept build-storybook as an alias to build:storybook for Chromatic's
  default script-name convention
---
 package.json | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/package.json b/package.json
index 93f01a6..a434a9f 100644
--- a/package.json
+++ b/package.json
@@ -46,17 +46,19 @@
   ],
   "scripts": {
     "dev": "storybook dev -p 3000 --host 0.0.0.0",
-    "build": "vite build",
+    "storybook": "storybook dev -p 3000 --host 0.0.0.0",
+    "build": "npm run build:storybook",
+    "build:storybook": "storybook build",
+    "build-storybook": "npm run build:storybook",
+    "build:package": "npm run build:react && npm run build:wc && npm run build:types",
     "build:react": "vite build --config vite.config.sdk.ts",
     "build:wc": "vite build --config vite.config.sdk.ts --mode wc",
     "build:types": "tsc --project tsconfig.build.json",
-    "build:all": "npm run clean && npm run build && npm run build:react && npm run build:wc && npm run build:types",
-    "preview": "vite preview",
+    "build:all": "npm run clean && npm run build:package",
+    "preview": "vite preview --outDir storybook-static",
     "clean": "rimraf dist server.js",
     "lint": "tsc --noEmit",
-    "prepublishOnly": "npm run build:all",
-    "storybook": "storybook dev -p 3000 --host 0.0.0.0",
-    "build-storybook": "storybook build"
+    "prepublishOnly": "npm run build:all"
   },
   "peerDependencies": {
     "canvas-confetti": "^1.9.4",
-- 
