{
  "name": "joyatwork",
  "version": "1.0.0",
  "description": "High-fidelity employee celebrations, anniversaries, and moments card system with cross-framework Web Component wrappers.",
  "homepage": "https://github.com/naveenraj06/joyatwork",
  "main": "./dist/react/index.umd.cjs",
  "module": "./dist/react/index.js",
  "types": "./dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naveenraj06/joyatwork.git"
  },
  "bugs": {
    "url": "https://github.com/naveenraj06/joyatwork/issues"
  },
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.umd.cjs"
    },
    "./web-components": {
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.umd.cjs"
    },
    "./wc-standalone": {
      "import": "./dist/wc/index.umd.cjs"
    },
    "./style.css": "./dist/react/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:react": "vite build --config vite.config.sdk.ts",
    "build:wc": "vite build --config vite.config.sdk.ts --mode wc",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types --noEmit false",
    "build:all": "npm run clean && npm run build && npm run build:react && npm run build:wc && npm run build:types",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
